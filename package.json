{
    "name": "skypanelv2",
    "description": "Open-source cloud service reseller billing panel with multi-provider support and white-label branding",
    "private": true,
    "version": "1.0.0",
    "engines": {
        "node": "22.22.0",
        "npm": ">=9"
    },
    "type": "module",
    "scripts": {
        "kill-ports": "npx kill-port 3001 5173 8000",
        "docs:api:sync": "node scripts/audit-api-docs.mjs --manifest-only",
        "docs:api:audit": "node scripts/audit-api-docs.mjs",
        "preclient:dev": "npm run docs:api:sync",
        "predev": "npm run docs:api:sync",
        "prebuild": "npm run docs:api:sync",
        "dev-up": "npx kill-port 3001 5173 8000 && npm run dev",
        "client:dev": "vite --host",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "check": "tsc --noEmit",
        "server:dev": "nodemon",
        "dev": "concurrently \"npm run client:dev\" \"npm run server:dev\"",
        "prestart": "npm run kill-ports",
        "start": "concurrently \"node --import tsx api/server.ts\" \"vite preview --port 5173 --strictPort\"",
        "pm2:start": "npm run kill-ports && npm run build && pm2 start ecosystem.config.cjs --env production",
        "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
        "pm2:stop": "pm2 stop skypanelv2-api skypanelv2-ui && pm2 delete skypanelv2-api skypanelv2-ui",
        "pm2:list": "pm2 ls",
        "ssl:caddy:help": "bash scripts/setup-caddy-ssl.sh --help",
        "seed:admin": "node scripts/seed-admin.js",
        "db:reset": "node scripts/reset-database.js",
        "db:reset:confirm": "node scripts/reset-database.js --confirm",
        "db:fresh": "node scripts/reset-database.js --confirm && node scripts/run-migration.js",
        "pwa:icons": "node scripts/generate-pwa-icons.js"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.927.0",
        "@aws-sdk/lib-storage": "^3.927.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hookform/resolvers": "^5.2.2",
        "@paypal/paypal-server-sdk": "^0.5.1",
        "@paypal/react-paypal-js": "^8.9.2",
        "@radix-ui/react-accordion": "^1.1.1",
        "@radix-ui/react-alert-dialog": "^1.1.3",
        "@radix-ui/react-avatar": "^1.1.10",
        "@radix-ui/react-checkbox": "^1.1.1",
        "@radix-ui/react-collapsible": "^1.1.12",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-hover-card": "^1.1.1",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-menubar": "^1.1.1",
        "@radix-ui/react-navigation-menu": "^1.1.3",
        "@radix-ui/react-popover": "^1.1.1",
        "@radix-ui/react-progress": "^1.1.7",
        "@radix-ui/react-scroll-area": "^1.1.0",
        "@radix-ui/react-select": "^2.1.1",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slider": "^1.1.1",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.1",
        "@radix-ui/react-toast": "^1.1.5",
        "@radix-ui/react-toggle": "^1.1.0",
        "@radix-ui/react-tooltip": "^1.2.8",
        "@tanstack/react-query": "^5.90.5",
        "@tanstack/react-table": "^8.20.4",
        "@types/pg": "^8.15.5",
        "@types/three": "^0.183.1",
        "@types/uuid": "^10.0.0",
        "axios": "^1.6.0",
        "bcryptjs": "^2.4.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "cors": "^2.8.5",
        "crypto-js": "^4.2.0",
        "date-fns": "^4.1.0",
        "dotenv": "^17.2.1",
        "express": "^4.21.2",
        "express-rate-limit": "^7.1.5",
        "express-validator": "^7.0.1",
        "framer-motion": "^12.23.24",
        "handlebars": "^4.7.8",
        "helmet": "^7.1.0",
        "input-otp": "^1.4.2",
        "jsonwebtoken": "^9.0.2",
        "lucide-react": "^0.511.0",
        "multer": "^2.0.0-rc.4",
        "next-themes": "^0.4.6",
        "nodemailer": "^7.0.11",
        "otplib": "^12.0.1",
        "pg": "^8.16.3",
        "qrcode": "^1.5.4",
        "react": "^18.3.1",
        "react-day-picker": "^9.11.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.65.0",
        "react-hot-toast": "^2.6.0",
        "react-router-dom": "^7.3.0",
        "react-simple-maps": "^3.0.0",
        "recharts": "^2.15.4",
        "resend": "^6.9.3",
        "sonner": "^1.7.4",
        "ssh2": "^1.17.0",
        "tailwind-merge": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "three": "^0.183.2",
        "uuid": "^13.0.0",
        "vaul": "^0.9.6",
        "ws": "^8.18.3",
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0",
        "xterm-addon-search": "^0.13.0",
        "xterm-addon-web-links": "^0.9.0",
        "zod": "^4.1.12",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.25.0",
        "@playwright/test": "^1.56.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/crypto-js": "^4.2.1",
        "@types/express": "^4.17.21",
        "@types/handlebars": "^4.0.40",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^1.4.11",
        "@types/node": "^22.19.0",
        "@types/nodemailer": "^6.4.14",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@types/supertest": "^6.0.3",
        "@vercel/node": "^5.5.15",
        "@vitejs/plugin-react": "^4.4.1",
        "autoprefixer": "^10.4.21",
        "babel-plugin-react-dev-locator": "^1.0.0",
        "baseline-browser-mapping": "^2.10.0",
        "concurrently": "^9.2.0",
        "eslint": "^9.25.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "fast-check": "^4.6.0",
        "globals": "^16.0.0",
        "jsdom": "^27.0.1",
        "nodemon": "^3.1.10",
        "playwright": "^1.56.1",
        "pm2": "^6.0.13",
        "postcss": "^8.5.3",
        "shadcn": "^3.5.0",
        "supertest": "^7.1.4",
        "tailwindcss": "^3.4.17",
        "tsx": "^4.20.3",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.30.1",
        "vite": "^6.3.5",
        "vite-plugin-pwa": "^1.2.0",
        "vite-plugin-trae-solo-badge": "^1.0.0",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.2.4"
    },
    "overrides": {
        "esbuild": "^0.25.0",
        "undici": "^6.0.0",
        "@vercel/node": {
            "path-to-regexp": "^8.0.0"
        }
    }
}
